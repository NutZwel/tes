{
  "comment": "Laufey (Music Player and Downloader) — Claude Code Harness Settings",
  "permissionMode": "default",
  "env": {
    "REQUIRED_VARS": ["base_url", "APP_PORT", "db_hostname", "db_database", "db_username", "db_password", "db_port", "session_encryption", "sess_expiration", "csrf_protection", "xor_key"]
  },
  "permissions": {
    "allow": [
      "Bash(php -l *)",
      "Bash(mysql *)",
      "Bash(cp *)",
      "Bash(git *)",
      "Bash(mysqldump *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(exec)",
      "Bash(rm -rf /)"
    ]
  }
}
